---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const reports = await getCollection('reports');
	return reports.map(report => ({
		params: { slug: report.id },
		props: { report },
	}));
}

const { report } = Astro.props;
const { Content, headings: renderedHeadings } = await render(report);

function formatDate(date: Date) {
	return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}

/** Show h2 headings in the TOC (main sections). Fall back to h3 if no h2 found. */
const h2s = renderedHeadings.filter(h => h.depth === 2);
const headings = h2s.length > 0 ? h2s : renderedHeadings.filter(h => h.depth === 3);
---

<BaseLayout title={`${report.data.title} — Beyond Paralysis`} description={report.data.executiveSummary}>
	<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

		<!-- PDF Download Banner -->
		{report.data.pdfUrl && (
			<a
				href={report.data.pdfUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-3 card-glow rounded-xl px-5 py-3 mb-8 no-underline hover:border-clinical-accent/30 transition group max-w-4xl"
			>
				<svg class="w-6 h-6 text-clinical-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
				</svg>
				<div>
					<span class="text-clinical-accent font-semibold text-sm group-hover:underline">Download Source PDF</span>
				</div>
			</a>
		)}

		<!-- Header -->
		<header class="mb-10 max-w-4xl">
			<div class="flex items-center gap-3 mb-4">
				<span class="inline-block w-1 h-8 rounded-full bg-clinical-accent"></span>
				<span class="text-sm text-slate-500">{formatDate(report.data.pubDate)}</span>
				<span class="text-sm text-clinical-accent font-medium">Deep Dive</span>
			</div>
			<h1 class="text-3xl sm:text-4xl font-bold leading-tight">{report.data.title}</h1>
			<p class="text-slate-400 mt-4 leading-relaxed text-lg border-l-2 border-clinical-accent/30 pl-4 italic">{report.data.executiveSummary}</p>
		</header>

		<!-- Podcast Player -->
		{report.data.audioUrl && (
			<div class="max-w-4xl mb-10">
				<div class="card-glow rounded-2xl p-6 border border-clinical-accent/20 bg-clinical-card">
					<div class="flex items-center gap-3 mb-4">
						<!-- Animated waveform icon -->
						<div class="flex items-end gap-[3px] h-6 shrink-0" aria-hidden="true">
							<span class="w-[3px] rounded-full bg-clinical-accent podcast-bar" style="height:40%;animation-delay:0s"></span>
							<span class="w-[3px] rounded-full bg-clinical-accent podcast-bar" style="height:80%;animation-delay:0.15s"></span>
							<span class="w-[3px] rounded-full bg-clinical-accent podcast-bar" style="height:55%;animation-delay:0.3s"></span>
							<span class="w-[3px] rounded-full bg-clinical-accent podcast-bar" style="height:100%;animation-delay:0.1s"></span>
							<span class="w-[3px] rounded-full bg-clinical-accent podcast-bar" style="height:65%;animation-delay:0.25s"></span>
						</div>
						<div>
							<p class="text-clinical-accent font-semibold text-sm tracking-wide uppercase">Listen to the Podcast</p>
							<p class="text-slate-400 text-xs mt-0.5">AI-generated audio overview of this Deep Dive report</p>
						</div>
					</div>

					<!-- Custom audio player -->
					<div class="flex items-center gap-4">
						<!-- Play/Pause button -->
						<button
							id="podcast-play-btn"
							aria-label="Play podcast"
							class="shrink-0 w-12 h-12 rounded-full bg-clinical-accent flex items-center justify-center hover:bg-cyan-300 transition-colors shadow-lg shadow-clinical-accent/30"
						>
							<!-- Play icon -->
							<svg id="podcast-play-icon" class="w-5 h-5 text-clinical-bg ml-0.5" fill="currentColor" viewBox="0 0 24 24">
								<path d="M8 5v14l11-7z"/>
							</svg>
							<!-- Pause icon (hidden initially) -->
							<svg id="podcast-pause-icon" class="w-5 h-5 text-clinical-bg hidden" fill="currentColor" viewBox="0 0 24 24">
								<path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
							</svg>
						</button>

						<!-- Scrubber + time -->
						<div class="flex-1 flex flex-col gap-1.5">
							<input
								id="podcast-scrubber"
								type="range"
								min="0"
								max="100"
								value="0"
								step="0.1"
								class="w-full h-1.5 rounded-full appearance-none cursor-pointer podcast-scrubber"
								aria-label="Audio progress"
							/>
							<div class="flex justify-between text-xs text-slate-500 tabular-nums">
								<span id="podcast-current">0:00</span>
								<span id="podcast-duration">--:--</span>
							</div>
						</div>
					</div>

					<audio id="podcast-audio" src={report.data.audioUrl} preload="metadata"></audio>
				</div>
			</div>
		)}

		<!-- Layout: Content + TOC sidebar -->
		<div class="grid grid-cols-1 lg:grid-cols-[1fr_240px] gap-10">

			<!-- Report Body -->
			<article class="report-content">
				<Content />
			</article>

			<!-- Sticky Table of Contents -->
			{headings.length > 0 && (
				<aside class="hidden lg:block">
					<nav class="sticky top-24">
						<div class="card-glow rounded-xl p-5">
							<h4 class="text-xs font-bold uppercase tracking-widest text-clinical-accent mb-4">On This Page</h4>
							<ul class="flex flex-col gap-2">
								{headings.map(h => (
									<li>
										<a
											href={`#${h.slug}`}
											class="text-xs text-slate-400 hover:text-clinical-accent transition-colors no-underline leading-snug block py-0.5"
										>
											{h.text}
										</a>
									</li>
								))}
							</ul>
						</div>
					</nav>
				</aside>
			)}
		</div>

		<!-- Back link -->
		<div class="mt-12 pt-6 border-t border-slate-700/50 max-w-4xl">
			<a href="/reports" class="text-sm text-clinical-accent hover:underline no-underline">&larr; All Deep Dives</a>
		</div>
	</main>
</BaseLayout>

<style is:global>
	/* ===== H2 Section Headings ===== */
	.report-content h2 {
		color: white;
		font-size: 1.5rem;
		font-weight: 700;
		margin: 0;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid rgba(0, 229, 255, 0.15);
		margin-bottom: 1rem;
		display: flex;
		align-items: center;
		gap: 0.625rem;
		scroll-margin-top: 6rem;
	}

	.report-content h2::before {
		content: '';
		display: inline-block;
		width: 4px;
		height: 1.5rem;
		border-radius: 2px;
		background: #00e5ff;
		flex-shrink: 0;
	}

	/* ===== H3 Sub-Section Headings ===== */
	.report-content h3 {
		color: white;
		font-size: 1.125rem;
		font-weight: 700;
		margin: 0;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid rgba(0, 229, 255, 0.10);
		margin-bottom: 0.75rem;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		scroll-margin-top: 6rem;
	}

	.report-content h3::before {
		content: '';
		display: inline-block;
		width: 3px;
		height: 1rem;
		border-radius: 2px;
		background: rgba(0, 229, 255, 0.5);
		flex-shrink: 0;
	}

	/* ===== Content Layout ===== */
	.report-content {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	/* Style paragraphs */
	.report-content p {
		color: rgb(148, 163, 184); /* slate-400 */
		line-height: 1.75;
		margin-bottom: 0.75rem;
	}

	.report-content strong {
		color: white;
	}

	/* Style lists */
	.report-content ul,
	.report-content ol {
		color: rgb(148, 163, 184);
		line-height: 1.75;
		padding-left: 1.25rem;
		margin-bottom: 0.75rem;
	}

	.report-content ul {
		list-style-type: disc;
	}

	.report-content ol {
		list-style-type: decimal;
	}

	.report-content li {
		margin-bottom: 0.5rem;
		padding-left: 0.25rem;
	}

	.report-content li::marker {
		color: #00e5ff;
	}

	/* Links */
	.report-content a {
		color: #00e5ff;
		text-decoration: none;
	}
	.report-content a:hover {
		text-decoration: underline;
	}

	/* ===== Section Cards ===== */
	.report-content .section-card {
		background: #1e293b;
		border: 1px solid rgba(0, 229, 255, 0.15);
		border-radius: 1rem;
		padding: 1.5rem;
		box-shadow:
			0 0 20px 0px rgba(0, 229, 255, 0.12),
			0 0 50px 0px rgba(0, 229, 255, 0.08),
			0 0 100px 0px rgba(0, 229, 255, 0.04),
			inset 0 1px 0 0 rgba(255, 255, 255, 0.05);
	}

	/* ===== Podcast Player ===== */
	.podcast-bar {
		animation: podcast-pulse 1.2s ease-in-out infinite alternate;
	}
	@keyframes podcast-pulse {
		from { transform: scaleY(0.4); }
		to   { transform: scaleY(1); }
	}

	.podcast-scrubber {
		background: rgba(0, 229, 255, 0.15);
		accent-color: #00e5ff;
	}
	.podcast-scrubber::-webkit-slider-thumb {
		appearance: none;
		width: 14px;
		height: 14px;
		border-radius: 50%;
		background: #00e5ff;
		cursor: pointer;
		box-shadow: 0 0 6px rgba(0, 229, 255, 0.7);
	}
	.podcast-scrubber::-moz-range-thumb {
		width: 14px;
		height: 14px;
		border-radius: 50%;
		background: #00e5ff;
		cursor: pointer;
		border: none;
		box-shadow: 0 0 6px rgba(0, 229, 255, 0.7);
	}

	/* Nested h3 cards inside h2 cards */
	.report-content .section-card .sub-section-card {
		background: rgba(15, 23, 42, 0.5);
		border: 1px solid rgba(0, 229, 255, 0.08);
		border-radius: 0.75rem;
		padding: 1.25rem;
	}
</style>

<script>
	// ===== Podcast Player =====
	const audio = document.getElementById('podcast-audio') as HTMLAudioElement | null;
	const playBtn = document.getElementById('podcast-play-btn');
	const playIcon = document.getElementById('podcast-play-icon');
	const pauseIcon = document.getElementById('podcast-pause-icon');
	const scrubber = document.getElementById('podcast-scrubber') as HTMLInputElement | null;
	const currentEl = document.getElementById('podcast-current');
	const durationEl = document.getElementById('podcast-duration');

	function formatTime(s: number): string {
		const m = Math.floor(s / 60);
		const sec = Math.floor(s % 60).toString().padStart(2, '0');
		return `${m}:${sec}`;
	}

	if (audio && playBtn && scrubber) {
		audio.addEventListener('loadedmetadata', () => {
			if (durationEl) durationEl.textContent = formatTime(audio.duration);
			scrubber.max = String(audio.duration);
		});

		audio.addEventListener('timeupdate', () => {
			if (currentEl) currentEl.textContent = formatTime(audio.currentTime);
			scrubber.value = String(audio.currentTime);
			// Update fill colour on scrubber track
			const pct = (audio.currentTime / audio.duration) * 100;
			scrubber.style.background = `linear-gradient(to right, #00e5ff ${pct}%, rgba(0,229,255,0.15) ${pct}%)`;
		});

		playBtn.addEventListener('click', () => {
			if (audio.paused) {
				audio.play();
				playIcon?.classList.add('hidden');
				pauseIcon?.classList.remove('hidden');
			} else {
				audio.pause();
				playIcon?.classList.remove('hidden');
				pauseIcon?.classList.add('hidden');
			}
		});

		audio.addEventListener('ended', () => {
			playIcon?.classList.remove('hidden');
			pauseIcon?.classList.add('hidden');
		});

		scrubber.addEventListener('input', () => {
			audio.currentTime = Number(scrubber.value);
		});
	}

	// Wrap sections in glowing card containers.
	// h2 sections become main cards; h3 sections inside them become sub-cards.
	document.addEventListener('DOMContentLoaded', () => {
		const content = document.querySelector('.report-content');
		if (!content) return;

		const children = Array.from(content.children);
		const hasH2 = children.some(c => c.tagName === 'H2');

		let currentCard: HTMLDivElement | null = null;
		let currentSubCard: HTMLDivElement | null = null;
		const fragment = document.createDocumentFragment();

		if (hasH2) {
			// H2-based structure: h2 = main card, h3 = sub-card inside
			for (const child of children) {
				if (child.tagName === 'H2') {
					// Close any open sub-card
					currentSubCard = null;
					// Start a new main section card
					currentCard = document.createElement('div');
					currentCard.className = 'section-card';
					currentCard.appendChild(child);
					fragment.appendChild(currentCard);
				} else if (child.tagName === 'H3' && currentCard) {
					// Start a sub-card within the current h2 card
					currentSubCard = document.createElement('div');
					currentSubCard.className = 'sub-section-card';
					currentSubCard.appendChild(child);
					currentCard.appendChild(currentSubCard);
				} else if (currentSubCard) {
					currentSubCard.appendChild(child);
				} else if (currentCard) {
					currentCard.appendChild(child);
				} else {
					// Content before first h2
					fragment.appendChild(child);
				}
			}
		} else {
			// H3-only structure (legacy Griffith/NervGen reports)
			for (const child of children) {
				if (child.tagName === 'H3') {
					currentCard = document.createElement('div');
					currentCard.className = 'section-card';
					currentCard.appendChild(child);
					fragment.appendChild(currentCard);
				} else if (currentCard) {
					currentCard.appendChild(child);
				} else {
					fragment.appendChild(child);
				}
			}
		}

		content.innerHTML = '';
		content.appendChild(fragment);
	});
</script>
